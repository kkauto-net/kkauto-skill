{
  "name": "kkauto-skill",
  "version": "0.1.2",
  "description": "Install and update kkAuto AI-agent skills and MCP config.",
  "type": "module",
  "bin": {
    "kkauto-skill": "dist/cli.js"
  },
  "files": [
    "dist",
    "docs",
    "skills",
    "templates",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && node scripts/copy-assets.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "pack:dry": "npm pack --dry-run"
  },
  "dependencies": {
    "@clack/prompts": "^0.10.1",
    "@iarna/toml": "^2.2.5",
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.15",
    "typescript": "^5.5.4",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "optionalDependencies": {
    "@rolldown/binding-linux-x64-gnu": "^1.0.2"
  }
}
